# Activar el motor de reescritura para limpiar URLs
RewriteEngine On

# 1. Si el usuario escribe una URL sin .html, el servidor busca si existe el archivo .html
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# 2. (Opcional) Redirección: Si alguien escribe explícitamente "archivo.html", 
# esta parte lo redirige a "archivo" para mantener todo limpio.
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.html [NC]
RewriteRule ^ %1 [R=301,L]
